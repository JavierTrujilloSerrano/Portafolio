{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server/package.json",
      "use": "vercel/node",
      "config": {
        "include": ["server/**/*"]
      }
    }
  ],
  "routes": [
    {
      "src": "/cv.pdf",
      "dest": "/server/public/cv.pdf",
      "headers": {
        "Content-Type": "application/pdf"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/client/$1"
    }
  ],
  "env": {
    "EMAIL": "vercel/env/EMAIL",
    "PASSWORD": "vercel/env/PASSWORD",
    "USER": "vercel/env/USER",
    "MESSAGE_SP": "vercel/env/MESSAGE_SP",
    "MESSAGE_EN": "vercel/env/MESSAGE_EN"
  },
  "build": {
    "env": {
      "NODE_ENV": "production"
    }
  }
}
